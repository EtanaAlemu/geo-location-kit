# Copy these lines into local.properties (gitignored; keep your sdk.dir=... line).

# --- Test published library in :app (geo.usePublished=true) ---

# GitHub Packages — works today for release 1.0.0 (group com.etanaalemu.geo):
geo.usePublished=true
geo.publishedGroup=com.etanaalemu.geo
geo.version=1.0.0
gpr.user=YOUR_GITHUB_USERNAME
gpr.key=ghp_...   # classic PAT with read:packages

# Maven Central — after you publish io.github.etanaalemu:geo-compose:1.0.1+ (no gpr needed):
# geo.usePublished=true
# geo.publishedGroup=io.github.etanaalemu
# geo.version=1.0.2

# Local modules (default for day-to-day dev):
# geo.usePublished=false
